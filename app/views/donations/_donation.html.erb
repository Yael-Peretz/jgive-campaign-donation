<div id="<%= dom_id(donation) %>" class="flex items-start justify-between gap-4 border-b border-gray-100 py-4 last:border-0">
  <div>
    <p class="font-medium text-gray-900">
      <%= donation.display_name %>
      <% if donation.monthly? %>
        <span class="ml-1 rounded-full bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-600">Monthly</span>
      <% end %>
    </p>

    <% if donation.dedication_message.present? %>
      <p class="mt-1 text-sm italic text-gray-500">&ldquo;<%= donation.dedication_message %>&rdquo;</p>
    <% end %>

    <p class="mt-1 text-xs text-gray-400"><%= time_ago_in_words(donation.created_at) %> ago</p>
  </div>

  <p class="whitespace-nowrap font-semibold text-gray-900">₪<%= number_with_delimiter(donation.amount.to_i) %></p>
</div>
