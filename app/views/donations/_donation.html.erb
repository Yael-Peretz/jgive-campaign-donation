<div id="<%= dom_id(donation) %>"
     class="flex flex-col justify-between rounded-xl border border-gray-200 bg-white p-4 shadow-sm">

  <%# Top row: amount + time ago %>
  <div class="flex items-start justify-between gap-2">
    <span class="text-xl font-bold text-gray-900">
      ₪<%= number_with_delimiter(donation.amount.to_i) %>
    </span>
    <span class="shrink-0 text-xs text-gray-400"><%= time_ago_in_words(donation.created_at) %> ago</span>
  </div>

  <%# Donor name + monthly badge %>
  <div class="mt-2">
    <% if donation.monthly? %>
      <span class="mb-1 inline-block rounded-full bg-purple-100 px-2 py-0.5 text-xs font-semibold text-purple-700">
        Monthly
      </span>
    <% end %>
    <p class="text-sm font-medium text-gray-800"><%= donation.display_name %></p>
  </div>

  <%# Dedication message %>
  <% if donation.dedication_message.present? %>
    <p class="mt-2 text-xs text-gray-500 italic leading-relaxed">
      &ldquo;<%= donation.dedication_message %>&rdquo;
    </p>
  <% end %>

  <%# Bottom: heart icon %>
  <div class="mt-3 flex justify-end">
    <button type="button" aria-label="Like" class="group cursor-pointer text-gray-300 hover:text-pink-500 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
      </svg>
    </button>
  </div>
</div>
