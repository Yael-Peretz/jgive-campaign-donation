<div id="<%= dom_id(campaign, :progress) %>">
  <div class="flex items-baseline justify-between text-sm font-medium text-gray-700">
    <span>₪<%= number_with_delimiter(campaign.raised_amount.to_i) %> raised</span>
    <span class="text-gray-500">of ₪<%= number_with_delimiter(campaign.goal_amount.to_i) %> goal</span>
  </div>

  <div class="mt-2 h-3 w-full overflow-hidden rounded-full bg-gray-200">
    <div class="h-full rounded-full bg-blue-600" style="width: <%= campaign.progress_percentage %>%"></div>
  </div>

  <div class="mt-1 text-sm text-gray-500">
    <%= pluralize(campaign.donations_count, "donation") %> &middot; <%= campaign.progress_percentage %>% funded
  </div>
</div>
