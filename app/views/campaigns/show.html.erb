<% content_for :title, @campaign.title %>

<% content_for :hero do %>
  <div data-controller="video">
    <%# Clickable thumbnail hero %>
    <div class="relative w-full h-72 sm:h-96 bg-black overflow-hidden cursor-pointer"
         data-action="click->video#open">
      <img src="https://img.youtube.com/vi/<%= @campaign.youtube_video_id %>/maxresdefault.jpg"
           alt="<%= @campaign.title %>"
           class="w-full h-full object-cover opacity-75">
      <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/70"></div>
      <div class="absolute bottom-0 left-0 p-6 sm:p-10">
        <h1 class="text-3xl sm:text-5xl font-extrabold text-orange-400 drop-shadow-lg leading-tight">
          <%= @campaign.title %>
        </h1>
        <p class="mt-2 text-white/90 text-sm sm:text-base max-w-xl"><%= @campaign.summary %></p>
      </div>
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div class="w-16 h-16 bg-white/90 rounded-full flex items-center justify-center shadow-xl">
          <svg class="w-7 h-7 text-gray-800 translate-x-0.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M8 5v14l11-7z"/>
          </svg>
        </div>
      </div>
    </div>

    <%# Stats bar %>
    <div class="bg-white border-b border-gray-200">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 py-5">
        <%= render "campaigns/progress_bar", campaign: @campaign %>
      </div>
    </div>

    <%# Video lightbox dialog %>
    <dialog data-video-target="dialog" data-action="click->video#closeBackdrop"
            class="m-auto w-full max-w-3xl bg-transparent p-4 backdrop:bg-black/80">
      <div class="relative bg-black rounded-xl overflow-hidden">
        <button type="button" data-action="click->video#close" aria-label="Close"
                class="absolute right-3 top-3 z-10 w-8 h-8 bg-black/60 rounded-full flex items-center justify-center text-white hover:bg-black cursor-pointer">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
        <div class="aspect-video">
          <iframe data-video-target="iframe"
                  data-src="https://www.youtube.com/embed/<%= @campaign.youtube_video_id %>?autoplay=1"
                  src=""
                  class="w-full h-full"
                  frameborder="0"
                  allow="autoplay; encrypted-media; fullscreen"
                  allowfullscreen></iframe>
        </div>
      </div>
    </dialog>
  </div>
<% end %>

<%# Two-column layout %>
<div class="mt-8 grid grid-cols-1 gap-8 lg:grid-cols-3">

  <%# Main content column (left, 2/3) %>
  <div class="lg:col-span-2" data-controller="tabs"
       data-tabs-active-class="border-purple-600 text-purple-700"
       data-tabs-inactive-class="border-transparent text-gray-500 hover:text-gray-700">

    <nav class="flex gap-x-1 overflow-x-auto border-b border-gray-200 scrollbar-none" role="tablist">
      <button type="button" role="tab" aria-selected="true"
              data-tabs-target="tab" data-action="click->tabs#select" data-tabs-name-param="about"
              class="cursor-pointer whitespace-nowrap border-b-2 border-purple-600 px-3 py-3 text-sm font-semibold text-purple-700">
        Project Info
      </button>
      <button type="button" role="tab" aria-selected="false"
              data-tabs-target="tab" data-action="click->tabs#select" data-tabs-name-param="donors"
              class="cursor-pointer whitespace-nowrap border-b-2 border-transparent px-3 py-3 text-sm font-semibold text-gray-500 hover:text-gray-700">
        Recent donations (<span id="donors-count"><%= @campaign.donations_count %></span>)
      </button>
      <span class="whitespace-nowrap border-b-2 border-transparent px-3 py-3 text-sm font-semibold text-gray-400 cursor-default select-none">Leaderboard</span>
      <span class="whitespace-nowrap border-b-2 border-transparent px-3 py-3 text-sm font-semibold text-gray-400 cursor-default select-none">Teams</span>
      <span class="whitespace-nowrap border-b-2 border-transparent px-3 py-3 text-sm font-semibold text-gray-400 cursor-default select-none">Non-Profit Info</span>
      <span class="whitespace-nowrap border-b-2 border-transparent px-3 py-3 text-sm font-semibold text-gray-400 cursor-default select-none">Updates</span>
    </nav>

    <%# Project Info panel %>
    <div data-tabs-target="panel" data-name="about" class="mt-6">
      <h2 class="text-xl font-bold text-gray-900 mb-5">About the Project</h2>
      <div class="story-content text-gray-700 leading-relaxed">
        <%= simple_format(@campaign.story) %>
      </div>
    </div>

    <%# Recent donations panel %>
    <div data-tabs-target="panel" data-name="donors" class="mt-6 hidden">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Recent Donations</h2>
      <p id="donors-empty" class="text-sm text-gray-500 <%= "hidden" if @recent_donations.any? %>">
        Be the first to donate!
      </p>
      <div id="donor-list" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <%= render @recent_donations %>
      </div>
    </div>
  </div>

  <%# Sidebar (right, 1/3) %>
  <div class="lg:col-span-1">
    <div class="sticky top-6 space-y-3" data-controller="modal">

      <%# bit button %>
      <a href="#" class="flex w-full items-center justify-center rounded-lg bg-[#1a3c5e] py-3 text-base font-bold text-white hover:bg-[#15304e] transition-colors">
        bit
      </a>

      <%# DONATE button %>
      <button type="button" data-action="click->modal#open"
              class="w-full cursor-pointer rounded-lg py-3 text-sm font-bold text-white tracking-wide transition-opacity hover:opacity-90"
              style="background: linear-gradient(to right, #9b27af, #e91e8c);">
        DONATE
      </button>

      <button class="w-full rounded-lg border-2 border-purple-500 py-3 text-sm font-semibold text-purple-600 hover:bg-purple-50 cursor-pointer transition-colors">
        Join as Participant
      </button>

      <%# Tax deductible badges %>
      <div class="flex items-center gap-2 text-xs text-gray-500 justify-center pt-1">
        <span>Tax deductible</span>
        <span class="text-base">🇮🇱</span>
        <span class="text-base">🇺🇸</span>
        <span class="text-base">🇨🇦</span>
      </div>

      <%# Share row %>
      <div class="flex items-center justify-center gap-4 pt-1">
        <a href="#" class="text-gray-400 hover:text-gray-600" aria-label="Share on X">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a href="#" class="text-gray-400 hover:text-green-500" aria-label="Share on WhatsApp">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>
        <a href="#" class="text-gray-400 hover:text-blue-600" aria-label="Share on Facebook">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      </div>

      <%# Donation modal dialog %>
      <dialog data-modal-target="dialog" data-action="click->modal#closeBackdrop"
              class="m-auto w-full max-w-md bg-transparent p-0 backdrop:bg-gray-900/50">
        <div class="relative">
          <button type="button" data-action="click->modal#close" aria-label="Close"
                  class="absolute right-4 top-4 z-10 cursor-pointer text-gray-400 hover:text-gray-600 text-xl leading-none">
            &#10005;
          </button>
          <%= render "donations/form", campaign: @campaign, donation: @donation %>
        </div>
      </dialog>
    </div>
  </div>

</div>
