<div id="<%= dom_id(campaign, :progress) %>">
  <%# Top row: raised amount + % funded badge %>
  <div class="flex items-center justify-between gap-4">
    <span class="text-3xl sm:text-4xl font-extrabold text-gray-900">
      ₪<%= number_with_delimiter(campaign.raised_amount.to_i) %>
    </span>
    <span class="shrink-0 rounded-full bg-purple-100 px-3 py-1 text-sm font-semibold text-purple-700">
      <%= campaign.progress_percentage < 1 && campaign.progress_percentage > 0 ? "< 1" : campaign.progress_percentage.to_i %>% funded
    </span>
  </div>

  <%# Gradient progress bar %>
  <% bar_width = campaign.raised_amount > 0 ? [campaign.progress_percentage, 0.5].max : 0 %>
  <div class="mt-3 h-3 w-full overflow-hidden rounded-full bg-gray-200">
    <div class="h-full rounded-full transition-all duration-500"
         style="width: <%= bar_width %>%;
                background: linear-gradient(to right, #f97316, #d946ef, #9333ea);"></div>
  </div>

  <%# Stats row %>
  <div class="mt-3 flex flex-wrap gap-x-8 gap-y-1 text-sm text-gray-500">
    <span>
      Number of donors:
      <strong class="font-semibold text-gray-800"><%= number_with_delimiter(campaign.donations_count) %></strong>
    </span>
    <span>
      Goal:
      <strong class="font-semibold text-gray-800">₪<%= number_with_delimiter(campaign.goal_amount.to_i) %></strong>
    </span>
  </div>
</div>
